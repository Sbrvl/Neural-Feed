{
  "manifest_version": 3,
  "name": "NeuralFeed",
  "version": "1.0.0",
  "description": "Brain activity analysis for social media reels powered by Meta TRIBE v2.",

  "permissions": [
    "tabCapture",
    "storage",
    "activeTab",
    "alarms",
    "offscreen",
    "sidePanel"
  ],

  "host_permissions": [
    "https://*.hf.space/*",
    "https://www.instagram.com/*",
    "https://www.tiktok.com/*",
    "https://www.youtube.com/*"
  ],

  "background": {
    "service_worker": "service_worker.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://www.tiktok.com/*",
        "https://www.youtube.com/shorts/*"
      ],
      "js": ["constants.js", "content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "popup.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
